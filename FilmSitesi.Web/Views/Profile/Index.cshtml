@model FilmSitesi.Web.Models.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Profil";
}

<div class="profile-page">
    <div class="profile-hero">
        <div class="profile-avatar">
            @Model.UserName.Substring(0, 1).ToUpper()
        </div>

        <div class="profile-hero-info">
            <h1>@Model.UserName</h1>
            <p>Film aktivitelerin, yorumların ve listelerin burada.</p>
        </div>
    </div>

    <div class="profile-hero-actions">
        @if (!Model.IsOwnProfile)
        {
            @if (Model.IsFollowing)
            {
                <form asp-action="Unfollow" method="post">
                    <input type="hidden" name="userId" value="@Model.UserId" />
                    <button type="submit" class="btn btn-outline-danger">Takibi Bırak</button>
                </form>
            }
            else
            {
                <form asp-action="Follow" method="post">
                    <input type="hidden" name="userId" value="@Model.UserId" />
                    <button type="submit" class="btn btn-primary">Takip Et</button>
                </form>
            }
        }
    </div>

    <div class="profile-stats">

        <a asp-controller="Profile"
           asp-action="Followers"
           asp-route-userId="@Model.UserId"
           class="profile-stat-card text-decoration-none text-dark">
            <span class="profile-stat-number">@Model.FollowersCount</span>
            <span class="profile-stat-label">Takipçi</span>
        </a>

        <a asp-controller="Profile"
           asp-action="Following"
           asp-route-userId="@Model.UserId"
           class="profile-stat-card text-decoration-none text-dark">
            <span class="profile-stat-number">@Model.FollowingCount</span>
            <span class="profile-stat-label">Takip</span>
        </a>

        <a asp-controller="Movies"
            asp-action="Watched"
            asp-route-userId="@Model.UserId"
            class="profile-stat-card text-decoration-none text-dark">
            <span class="profile-stat-number">@Model.WatchedCount</span>
            <span class="profile-stat-label">İzlenen Film</span>
        </a>

        <a asp-controller="Movies"
            asp-action="Watchlist"
            asp-route-userId="@Model.UserId"
            class="profile-stat-card text-decoration-none text-dark">
            <span class="profile-stat-number">@Model.WatchlistCount</span>
            <span class="profile-stat-label">Watchlist</span>
        </a>

        <a href="#recent-reviews" class="profile-stat-card text-decoration-none text-dark">
            <span class="profile-stat-number">@Model.ReviewCount</span>
            <span class="profile-stat-label">Yorum</span>
        </a>

    </div>

    <div class="profile-section">
        <div class="section-title-row">
            <h3>Son İzlenen Filmler</h3>
        </div>

        @if (Model.RecentWatched != null && Model.RecentWatched.Any())
        {
            <div class="poster-grid">
                @foreach (var item in Model.RecentWatched)
                {
                    <a asp-controller="Movies"
                       asp-action="Detail"
                       asp-route-id="@item.Movie.TmdbId"
                       class="poster-card-link">
                        <div class="poster-card">
                            <div class="movie-poster-wrapper hover-poster-card">
                                @if (!string.IsNullOrWhiteSpace(item.Movie.PosterPath))
                                {
                                    <img class="movie-poster"
                                        src="@($"https://image.tmdb.org/t/p/w500{item.Movie.PosterPath}")"
                                        alt="@item.Movie.Title" />
                                }
                                else
                                {
                                    <div class="movie-poster-placeholder">No Image</div>
                                }

                                <div class="poster-overlay">
                                    <div class="poster-overlay-content">
                                        <div class="poster-overlay-title">
                                            @item.Movie.Title
                                        </div>

                                        <div class="poster-overlay-rating">
                                            İzleme: @item.WatchedDate.ToLocalTime().ToString("dd.MM.yyyy")
                                        </div>

                                        <span class="btn btn-light btn-sm poster-overlay-button">
                                            Filme Git
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="poster-card-body">
                                <h6>@item.Movie.Title</h6>
                                <small>@item.WatchedDate.ToLocalTime().ToString("dd.MM.yyyy")</small>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-feed">
                <p>Henüz izlenen film yok.</p>
            </div>
        }
    </div>

    <div class="profile-section" id="recent-reviews">
        <div class="section-title-row">
            <h3>Son Yorumlar</h3>
        </div>

        @if (Model.RecentReviews != null && Model.RecentReviews.Any())
        {
            <div class="stack-list">
                @foreach (var review in Model.RecentReviews)
                {
                    <div class="stack-card">
                        <div class="stack-card-header">
                            <a asp-controller="Movies"
                               asp-action="Detail"
                               asp-route-id="@review.Movie.TmdbId"
                               class="movie-link">
                                @review.Movie.Title
                            </a>

                            <span class="review-rating-badge">
                                ⭐ @review.Rating.ToString("0.0") / 5
                            </span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(review.Comment))
                        {
                            <p class="stack-card-text">@review.Comment</p>
                        }

                        <small class="text-muted">
                            @review.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </small>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-feed">
                <p>Henüz yorum yok.</p>
            </div>
        }
    </div>

    <div class="profile-section">
        <div class="section-title-row">
            <h3>Aktivitelerim</h3>
        </div>

        @if (Model.RecentActivities != null && Model.RecentActivities.Any())
        {
            <div class="stack-list">
                @foreach (var activity in Model.RecentActivities)
                {
                    <div class="stack-card">
                        @if (activity.Type == "Review")
                        {
                            <p>
                                <strong>@activity.MovieTitle</strong> filmine
                                <strong>@activity.Rating?.ToString("0.0") / 5</strong>
                                verdin.
                            </p>
                        }
                        else if (activity.Type == "Watched")
                        {
                            <p>
                                <strong>@activity.MovieTitle</strong> filmini izledin.
                            </p>
                        }
                        else if (activity.Type == "Watchlist")
                        {
                            <p>
                                <strong>@activity.MovieTitle</strong> filmini watchlist'ine ekledin.
                            </p>
                        }

                        @if (!string.IsNullOrWhiteSpace(activity.Note))
                        {
                            <div class="activity-note">@activity.Note</div>
                        }

                        <small class="text-muted">
                            @activity.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </small>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-feed">
                <p>Henüz aktiviten yok.</p>
            </div>
        }
    </div>
</div>