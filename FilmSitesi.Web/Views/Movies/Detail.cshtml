@model FilmSitesi.Web.Models.ViewModels.MovieDetailViewModel

@{
    ViewData["Title"] = "Film Detayı";
}

<div class="movie-detail-hero">
    <div class="movie-detail-poster">
        @if (!string.IsNullOrWhiteSpace(Model.Movie.PosterPath))
        {
            <img src="@($"https://image.tmdb.org/t/p/w500{Model.Movie.PosterPath}")" alt="@Model.Movie.Title" />
        }
        else
        {
            <div class="movie-detail-placeholder">No Image</div>
        }
    </div>

    <div class="movie-detail-info">
        <div class="movie-detail-heading">
            <h1>@Model.Movie.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Movie.OriginalTitle) && Model.Movie.OriginalTitle != Model.Movie.Title)
            {
                <p class="original-title">@Model.Movie.OriginalTitle</p>
            }
        </div>

        <div class="movie-detail-stats">
            <div class="detail-stat-card">
                <span class="detail-stat-label">TMDb</span>
                <span class="detail-stat-value">⭐ @Model.Movie.VoteAverage.ToString("0.0")</span>
            </div>

            <div class="detail-stat-card">
                <span class="detail-stat-label">Kullanıcı</span>
                @if (Model.RatingCount > 0)
                {
                    <span class="detail-stat-value">⭐ @Model.AverageRating.ToString("0.0")</span>
                }
                else
                {
                    <span class="detail-stat-value">Henüz puan yok</span>
                }
            </div>

            <div class="detail-stat-card">
                <span class="detail-stat-label">Yorum</span>
                <span class="detail-stat-value">@Model.RatingCount kişi</span>
            </div>
        </div>

        <div class="movie-detail-meta">
            <span><strong>Çıkış:</strong> @(Model.Movie.ReleaseDate?.ToString("dd.MM.yyyy") ?? "-")</span>
            <span><strong>Dil:</strong> @Model.Movie.OriginalLanguage</span>
        </div>

        <div class="movie-detail-overview">
            <h4>Özet</h4>
            <p>@Model.Movie.Overview</p>
        </div>
    </div>
</div>

<div class="movie-detail-sections">

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="detail-card">
            <h3>İzledim</h3>

            @if (Model.HasWatched)
            {
                <p class="mb-3"><strong>Bu filmi @Model.WatchedCount kez izledin.</strong></p>
            }
            else
            {
                <p class="text-muted">İzlediğinde kütüphanene eklemek için işaretleyebilirsin.</p>
            }

            <form asp-action="AddWatched" method="post">
                <input type="hidden" name="movieId" value="@Model.Movie.Id" />

                <button type="submit" class="btn btn-success">
                    @(Model.HasWatched ? "Tekrar İzledim Olarak Ekle" : "İzledim Olarak İşaretle")
                </button>
            </form>
        </div>
    }
    else
    {
        <div class="detail-card">
            <h3>İzledim</h3>
            <p>
                İzledim listesi kullanmak için
                <a asp-area="Identity" asp-page="/Account/Login">giriş yap</a>.
            </p>
        </div>
    }

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="detail-card">
            <h3>Watchlist</h3>

            @if (TempData["WatchlistError"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["WatchlistError"]
                </div>
            }

            @if (!Model.IsInWatchlist)
            {
                <p class="text-muted">Bu filmi daha sonra izlemek için listene ekleyebilirsin.</p>

                <form asp-action="AddToWatchlist" method="post">
                    <input type="hidden" name="movieId" value="@Model.Movie.Id" />
                    <button type="submit" class="btn btn-warning">Watchlist'e Ekle</button>
                </form>
            }
            else
            {
                <p class="mb-3"><strong>Bu film watchlist'inde.</strong></p>

                <form asp-action="RemoveFromWatchlist" method="post">
                    <input type="hidden" name="movieId" value="@Model.Movie.Id" />
                    <button type="submit" class="btn btn-outline-danger">Watchlist'ten Çıkar</button>
                </form>
            }
        </div>
    }
    else
    {
        <div class="detail-card">
            <h3>Watchlist</h3>
            <p>
                Watchlist kullanmak için
                <a asp-area="Identity" asp-page="/Account/Login">giriş yap</a>.
            </p>
        </div>
    }

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="detail-card">
            <h3>Puan Ver / Yorum Yaz</h3>

            @if (TempData["ReviewError"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ReviewError"]
                </div>
            }

            <form asp-action="AddReview" method="post">
                <input type="hidden" name="movieId" value="@Model.Movie.Id" />

                <div class="mb-3">
                    <label class="form-label d-block">Puan</label>

                    <input type="hidden"
                           id="ratingInput"
                           name="rating"
                           value="@(Model.UserRating?.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                           required />

                    <div class="star-rating-5" id="starRating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <div class="star-wrapper" data-star="@i">
                                <svg class="star-svg star-bg" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 2.5l2.94 5.96 6.58.96-4.76 4.64 1.12 6.56L12 17.52 6.12 20.62l1.12-6.56L2.48 9.42l6.58-.96L12 2.5z" />
                                </svg>

                                <div class="star-fill-box">
                                    <svg class="star-svg star-fill" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 2.5l2.94 5.96 6.58.96-4.76 4.64 1.12 6.56L12 17.52 6.12 20.62l1.12-6.56L2.48 9.42l6.58-.96L12 2.5z" />
                                    </svg>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-3 rating-selected-box">
                        Seçilen puan:
                        <strong id="ratingValue">
                            @(Model.UserRating.HasValue ? Model.UserRating.Value.ToString("0.0") : "Yok")
                        </strong>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Yorum</label>
                    <textarea name="comment" class="form-control" rows="4">@Model.UserComment</textarea>
                </div>

                <button type="submit" class="btn btn-primary">
                    @(Model.UserRating.HasValue || !string.IsNullOrWhiteSpace(Model.UserComment) ? "Puanı / Yorumu Güncelle" : "Puanla ve Kaydet")
                </button>
            </form>
        </div>
    }
    else
    {
        <div class="detail-card">
            <h3>Puan Ver / Yorum Yaz</h3>
            <p>
                Yorum ve puan vermek için
                <a asp-area="Identity" asp-page="/Account/Login">giriş yap</a>.
            </p>
        </div>
    }

    <div class="detail-card">
        <h3>Yorumlar</h3>

        @if (Model.Reviews.Any(r => !string.IsNullOrWhiteSpace(r.Comment)))
        {
            @foreach (var review in Model.Reviews.Where(r => !string.IsNullOrWhiteSpace(r.Comment)))
            {
                <div class="stack-card">
                    <div class="stack-card-header">
                        <strong>@review.UserName</strong>

                        <span class="review-rating-badge">
                            ⭐ @review.Rating.ToString("0.0") / 5
                        </span>
                    </div>

                    <p class="stack-card-text">@review.Comment</p>

                    <div class="d-flex align-items-center justify-content-between mt-3">
                        <small class="text-muted">
                            @review.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </small>

                        <div class="d-flex align-items-center gap-2">
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <button type="button"
                                        class="btn btn-sm review-like-btn @(review.IsLikedByCurrentUser ? "btn-primary" : "btn-outline-secondary")"
                                        data-review-id="@review.Id">
                                    👍 <span class="like-count">@review.LikeCount</span>
                                </button>
                            }
                            else
                            {
                                <span class="btn btn-sm btn-outline-secondary disabled">
                                    👍 <span class="like-count">@review.LikeCount</span>
                                </span>
                            }

                            <a asp-controller="Movies"
                            asp-action="ReviewLikes"
                            asp-route-reviewId="@review.Id"
                            class="btn btn-sm btn-outline-dark">
                                Beğenenler
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p>Henüz yorum yok.</p>
        }
    </div>
</div>







<style>
    .star-rating-5 {
        display: flex;
        gap: 10px;
        align-items: center;
        user-select: none;
    }

    .star-wrapper {
        position: relative;
        width: 38px;
        height: 38px;
        cursor: pointer;
        flex: 0 0 auto;
    }

    .star-svg {
        width: 38px;
        height: 38px;
        display: block;
    }

    .star-bg {
        position: absolute;
        inset: 0;
        fill: #d1d5db;
    }

    .star-fill-box {
        position: absolute;
        inset: 0;
        width: 0%;
        overflow: hidden;
        transition: width 0.12s ease;
    }

    .star-fill {
        fill: #f5c518;
    }

    .star-wrapper:hover {
        transform: scale(1.05);
    }

    .rating-selected-box {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff8db;
        color: #7a5a00;
        border-radius: 999px;
        padding: 8px 12px;
        font-weight: 600;
    }
</style>









<script>
    document.addEventListener("DOMContentLoaded", function () {
        const starContainer = document.getElementById("starRating");
        const starWrappers = document.querySelectorAll(".star-wrapper");
        const ratingInput = document.getElementById("ratingInput");
        const ratingValue = document.getElementById("ratingValue");

        function paintStars(value) {
            starWrappers.forEach((star, index) => {
                const starNumber = index + 1;
                const fill = star.querySelector(".star-fill-box");

                if (value >= starNumber) {
                    fill.style.width = "100%";
                } else if (value >= starNumber - 0.5) {
                    fill.style.width = "50%";
                } else {
                    fill.style.width = "0%";
                }
            });
        }

        function setRating(value) {
            ratingInput.value = value.toFixed(1);
            ratingValue.textContent = value.toFixed(1);
            paintStars(value);
        }

        starWrappers.forEach((star, index) => {
            star.addEventListener("mousemove", function (e) {
                const rect = star.getBoundingClientRect();
                const offsetX = e.clientX - rect.left;
                const isLeftHalf = offsetX < rect.width / 2;

                const starNumber = index + 1;
                const hoverValue = isLeftHalf ? starNumber - 0.5 : starNumber;

                paintStars(hoverValue);
            });

            star.addEventListener("click", function (e) {
                const rect = star.getBoundingClientRect();
                const offsetX = e.clientX - rect.left;
                const isLeftHalf = offsetX < rect.width / 2;

                const starNumber = index + 1;
                const selectedValue = isLeftHalf ? starNumber - 0.5 : starNumber;

                setRating(selectedValue);
            });
        });

        if (starContainer) {
            starContainer.addEventListener("mouseleave", function () {
                const currentValue = parseFloat(ratingInput.value);
                if (!isNaN(currentValue)) {
                    paintStars(currentValue);
                } else {
                    paintStars(0);
                }
            });
        }

        const initialValue = parseFloat(ratingInput.value);
        if (!isNaN(initialValue)) {
            paintStars(initialValue);
        } else {
            paintStars(0);
        }
    });
</script>




<script>
    document.addEventListener("DOMContentLoaded", function () {
        const likeButtons = document.querySelectorAll(".review-like-btn");

        likeButtons.forEach(button => {
            button.addEventListener("click", async function () {
                const reviewId = this.dataset.reviewId;

                try {
                    const response = await fetch('/Movies/ToggleLike', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: `reviewId=${encodeURIComponent(reviewId)}`
                    });

                    if (!response.ok) {
                        console.error("Like isteği başarısız.");
                        return;
                    }

                    const data = await response.json();

                    if (data.success) {
                        const likeCountSpan = this.querySelector(".like-count");
                        likeCountSpan.textContent = data.likeCount;

                        if (data.liked) {
                            this.classList.remove("btn-outline-secondary");
                            this.classList.add("btn-primary");
                        } else {
                            this.classList.remove("btn-primary");
                            this.classList.add("btn-outline-secondary");
                        }
                    }
                } catch (error) {
                    console.error("Like sırasında hata:", error);
                }
            });
        });
    });
</script>


